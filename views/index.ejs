<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <% const safeAppName = typeof appName !== "undefined" && appName ? appName : "DiscordCDN"; %>
  <% const safeFavicon = typeof appFavicon !== "undefined" && appFavicon ? appFavicon : "/assets/logo.ico"; %>
  <% const safeDiscord = typeof discordInvite !== "undefined" && discordInvite ? discordInvite : "#"; %>
  <% const safeTwitter = typeof twitterInvite !== "undefined" && twitterInvite ? twitterInvite : "#"; %>
  <% const safeFacebook = typeof facebookInvite !== "undefined" && facebookInvite ? facebookInvite : "#"; %>
  <% const safeInstagram = typeof instagramInvite !== "undefined" && instagramInvite ? instagramInvite : "#"; %>
  <% const safeLinkedin = typeof linkedinInvite !== "undefined" && linkedinInvite ? linkedinInvite : "#"; %>

  <title><%= safeAppName %> | Discord File Hosting</title>
  <meta name="description"
    content="<%= safeAppName %> helps you upload files, generate stable Discord-ready links, and ship shareable embeds with a premium developer-first workflow.">
  <meta name="keywords" content="discord, file hosting, embed hosting, image upload, shareable links">
  <link href="<%= safeFavicon %>" rel="icon">
  <link href="assets/img/apple-touch-icon.png" rel="apple-touch-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link href="assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="assets/css/style.css" rel="stylesheet">
</head>

<body class="theme-dark">
  <div class="site-shell">
    <div class="bg-orb bg-orb-one" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-two" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>

    <header class="site-header" id="top">
      <div class="container nav-shell">
        <a class="brand-mark" href="/" aria-label="<%= safeAppName %> home">
          <span class="brand-icon">D</span>
          <span class="brand-copy">
            <strong><%= safeAppName %></strong>
            <small>Embed hosting for Discord</small>
          </span>
        </a>

        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation" data-nav-toggle>
          <span></span>
          <span></span>
        </button>

        <nav class="site-nav" id="site-nav" data-nav-panel>
          <a href="#features">Features</a>
          <a href="#workflow">Workflow</a>
          <a href="#upload">Upload</a>
          <a href="#footer-newsletter">Updates</a>
          <a href="<%= safeDiscord %>" target="_blank" rel="noreferrer">Discord</a>
          <a href="https://github.com/NicoRuizDev/DiscordCDN" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero-section">
        <div class="container hero-grid">
          <div class="hero-copy reveal">
            <span class="eyebrow">Stable links. Better embeds. Zero friction.</span>
            <h1>Host images and files with a polished Discord-native workflow.</h1>
            <p class="hero-text">
              <%= safeAppName %> turns uploads into clean, dependable share links built for Discord previews, social embeds,
              bots, and developer tooling. Fast to use, easy to trust, and designed like a real product.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#upload">Start Uploading</a>
              <a class="button button-secondary" href="https://docs.nicoruiz.dev" target="_blank" rel="noreferrer">Read Docs</a>
            </div>

            <ul class="hero-points" aria-label="Key benefits">
              <li>Stable shareable file URLs</li>
              <li>Discord-friendly preview workflow</li>
              <li>API-ready for automation</li>
            </ul>
          </div>

          <div class="hero-panel reveal">
            <div class="glass-panel spotlight-card">
              <div class="panel-badge">
                <span class="status-dot"></span>
                Live upload pipeline
              </div>
              <div class="mock-window">
                <div class="mock-window-bar">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <div class="mock-window-body">
                  <div class="metric-row">
                    <div>
                      <small>Avg. share time</small>
                      <strong>Under 10s</strong>
                    </div>
                    <div>
                      <small>Delivery mode</small>
                      <strong>Direct + embed links</strong>
                    </div>
                  </div>
                  <div class="mock-link-card">
                    <span class="tag">Generated URL</span>
                    <code>https://your-domain/files/x7Bf2jP91kq4R8nLmQ2v.png</code>
                  </div>
                  <div class="discord-preview">
                    <div class="discord-bar"></div>
                    <div class="discord-content">
                      <strong><%= safeAppName %></strong>
                      <p>Preview-ready image card for Discord and social embeds.</p>
                      <div class="preview-image-glow"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="features">
        <div class="container">
          <div class="section-heading reveal">
            <span class="eyebrow">Product Value</span>
            <h2>Built for creators, communities, and developer workflows</h2>
            <p>A modern Discord-focused hosting surface with premium UX and practical delivery paths.</p>
          </div>

          <div class="feature-grid">
            <article class="glass-panel feature-card reveal">
              <div class="feature-icon"><i class="bi bi-cloud-arrow-up"></i></div>
              <h3>Upload files</h3>
              <p>Drag, drop, and ship images or assets through a clean interface that feels fast on desktop and mobile.</p>
            </article>

            <article class="glass-panel feature-card reveal">
              <div class="feature-icon"><i class="bi bi-discord"></i></div>
              <h3>Generate embed links</h3>
              <p>Get stable shareable URLs designed to work cleanly in Discord previews and external social cards.</p>
            </article>

            <article class="glass-panel feature-card reveal">
              <div class="feature-icon"><i class="bi bi-activity"></i></div>
              <h3>Track uploads</h3>
              <p>Present a trustworthy operational feel with upload details, file stats, and result-state clarity.</p>
            </article>

            <article class="glass-panel feature-card reveal">
              <div class="feature-icon"><i class="bi bi-code-slash"></i></div>
              <h3>API support</h3>
              <p>Fits automated pipelines too, with token-based API uploads preserved for scripts, bots, and integrations.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="workflow">
        <div class="container">
          <div class="workflow-grid">
            <article class="glass-panel workflow-card reveal">
              <span class="step-chip">01</span>
              <h3>Select a file</h3>
              <p>Choose media, screenshots, assets, or docs through a high-clarity upload surface.</p>
            </article>
            <article class="glass-panel workflow-card reveal">
              <span class="step-chip">02</span>
              <h3>Generate a stable link</h3>
              <p>The existing backend creates a hosted asset URL and a dedicated share page for embeds.</p>
            </article>
            <article class="glass-panel workflow-card reveal">
              <span class="step-chip">03</span>
              <h3>Share anywhere</h3>
              <p>Drop the link into Discord, docs, websites, or internal tools and keep a polished preview experience.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-upload" id="upload">
        <div class="container upload-layout">
          <div class="section-heading reveal">
            <span class="eyebrow">Upload Console</span>
            <h2>Premium upload experience, same backend behavior</h2>
            <p>The form still posts to the current upload route and keeps the existing file field name intact.</p>
          </div>

          <div class="upload-grid">
            <form class="glass-panel upload-card reveal" method="POST" action="/upload" enctype="multipart/form-data" data-upload-form>
              <label class="upload-zone" for="files" data-upload-zone tabindex="0">
                <input class="sr-only" type="file" id="files" name="myFile" multiple="multiple" data-file-input>
                <span class="upload-icon"><i class="bi bi-image"></i></span>
                <strong data-upload-title>Drop files here or click to browse</strong>
                <span data-upload-subtitle>Supports images, videos, and general files with your current upload route.</span>
                <span class="upload-file-name" data-file-name>No file selected</span>
              </label>

              <div class="upload-actions">
                <button class="button button-primary button-full" type="submit" data-submit-button>
                  <span class="button-label">Upload Files</span>
                  <span class="button-loading">Uploading...</span>
                </button>
              </div>
            </form>

            <aside class="glass-panel info-card reveal">
              <span class="panel-label">Why teams use it</span>
              <ul class="signal-list">
                <li>Share image embeds in Discord without exposing messy file storage paths.</li>
                <li>Keep an easy human-friendly upload flow alongside API automation.</li>
                <li>Maintain a trustworthy, production-quality front door for a lightweight service.</li>
              </ul>
              <div class="mini-stats">
                <div>
                  <small>Routes preserved</small>
                  <strong>`/upload`, `/files/*`</strong>
                </div>
                <div>
                  <small>Storage preserved</small>
                  <strong>Local + Vercel Blob</strong>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer" id="footer-newsletter">
      <div class="container footer-grid">
        <div class="footer-brand">
          <a class="brand-mark brand-mark-footer" href="/">
            <span class="brand-icon">D</span>
            <span class="brand-copy">
              <strong><%= safeAppName %></strong>
              <small>Clean delivery for Discord-ready assets</small>
            </span>
          </a>
          <p>Upload once, share confidently, and keep your lightweight hosting service feeling like a premium SaaS product.</p>
          <div class="social-row" aria-label="Social links">
            <a href="<%= safeTwitter %>" aria-label="Twitter" target="_blank" rel="noreferrer"><i class="bi bi-twitter-x"></i></a>
            <a href="<%= safeFacebook %>" aria-label="Facebook" target="_blank" rel="noreferrer"><i class="bi bi-facebook"></i></a>
            <a href="<%= safeInstagram %>" aria-label="Instagram" target="_blank" rel="noreferrer"><i class="bi bi-instagram"></i></a>
            <a href="<%= safeLinkedin %>" aria-label="LinkedIn" target="_blank" rel="noreferrer"><i class="bi bi-linkedin"></i></a>
          </div>
        </div>

        <div class="footer-newsletter glass-panel">
          <span class="panel-label">Stay in the loop</span>
          <h3>Get product updates</h3>
          <p>Subscribe for release notes, improvements, and tooling updates.</p>
          <form action="/subscribe" method="post" class="newsletter-form">
            <label class="sr-only" for="email">Email address</label>
            <input id="email" type="email" name="email" placeholder="Enter your email" aria-describedby="emailHelp" required>
            <button class="button button-primary" type="submit">Subscribe</button>
          </form>
        </div>
      </div>
    </footer>
  </div>

  <script src="assets/js/main.js"></script>
</body>

</html>
