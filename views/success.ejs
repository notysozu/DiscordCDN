<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <% const safeAppName = typeof appName !== "undefined" && appName ? appName : "DiscordCDN"; %>
  <% const safeFavicon = typeof appFavicon !== "undefined" && appFavicon ? appFavicon : "/assets/logo.ico"; %>
  <% const safeDiscord = typeof discordInvite !== "undefined" && discordInvite ? discordInvite : "#"; %>
  <% const safeTwitter = typeof twitterInvite !== "undefined" && twitterInvite ? twitterInvite : "#"; %>
  <% const safeFacebook = typeof facebookInvite !== "undefined" && facebookInvite ? facebookInvite : "#"; %>
  <% const safeInstagram = typeof instagramInvite !== "undefined" && instagramInvite ? instagramInvite : "#"; %>
  <% const safeLinkedin = typeof linkedinInvite !== "undefined" && linkedinInvite ? linkedinInvite : "#"; %>
  <% const safeUploadLink = typeof uploadLink !== "undefined" && uploadLink ? uploadLink : ""; %>
  <% const safeFileLink = typeof fileLink !== "undefined" && fileLink ? fileLink : ""; %>
  <% const safeFileName = typeof fileName !== "undefined" && fileName ? fileName : "Unknown file"; %>
  <% const safeFileSize = typeof fileSize !== "undefined" && fileSize ? fileSize : "Unknown size"; %>
  <% const isImage = safeUploadLink && /\.(png|jpe?g|gif|webp|svg|bmp|avif)$/i.test(safeUploadLink); %>

  <title><%= safeAppName %> | Upload Complete</title>
  <meta name="description" content="Your file has been uploaded successfully. Copy the shareable Discord-ready link from <%= safeAppName %>.">
  <link href="<%= safeFavicon %>" rel="icon">
  <link href="assets/img/apple-touch-icon.png" rel="apple-touch-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link href="assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="assets/css/style.css" rel="stylesheet">
</head>

<body class="theme-dark">
  <div class="site-shell site-shell-compact">
    <div class="bg-orb bg-orb-one" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-two" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container nav-shell">
        <a class="brand-mark" href="/" aria-label="<%= safeAppName %> home">
          <span class="brand-icon">D</span>
          <span class="brand-copy">
            <strong><%= safeAppName %></strong>
            <small>Upload result</small>
          </span>
        </a>

        <nav class="site-nav site-nav-inline">
          <a href="/">New Upload</a>
          <a href="<%= safeDiscord %>" target="_blank" rel="noreferrer">Discord</a>
          <a href="https://github.com/NicoRuizDev/DiscordCDN" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="page-main">
      <section class="section result-section">
        <div class="container">
          <div class="result-grid">
            <article class="glass-panel result-card reveal">
              <span class="eyebrow">Upload Complete</span>
              <h1>Your file is live and ready to share.</h1>
              <p>Copy the generated link, preview the hosted asset, or start another upload without leaving the flow.</p>

              <div class="link-stack">
                <label for="generated-link">Generated share page</label>
                <div class="copy-field">
                  <input id="generated-link" type="text" value="<%= safeFileLink %>" readonly data-copy-input>
                  <button class="button button-primary" type="button" data-copy-button data-copy-value="<%= safeFileLink %>">
                    <span class="copy-default">Copy Link</span>
                    <span class="copy-success">Copied</span>
                  </button>
                </div>
              </div>

              <div class="detail-grid">
                <div class="detail-item">
                  <small>Stored file name</small>
                  <strong><%= safeFileName %></strong>
                </div>
                <div class="detail-item">
                  <small>Estimated size</small>
                  <strong><%= safeFileSize %></strong>
                </div>
                <div class="detail-item">
                  <small>Direct asset</small>
                  <strong><a href="<%= safeUploadLink %>" target="_blank" rel="noreferrer">Open file</a></strong>
                </div>
              </div>

              <div class="hero-actions">
                <a class="button button-secondary" href="/">Upload Another</a>
                <a class="button button-ghost" href="<%= safeFileLink %>" target="_blank" rel="noreferrer">Open Share Page</a>
              </div>
            </article>

            <aside class="glass-panel preview-card reveal">
              <span class="panel-label">Preview</span>
              <h2>Discord-style appearance</h2>
              <div class="discord-preview discord-preview-large">
                <div class="discord-bar"></div>
                <div class="discord-content">
                  <strong><%= safeAppName %></strong>
                  <p>Hosted asset ready for previews and clean social sharing.</p>
                  <% if (safeUploadLink && isImage) { %>
                    <img src="<%= safeUploadLink %>" alt="Uploaded file preview" class="result-image-preview">
                  <% } else { %>
                    <div class="file-placeholder">
                      <i class="bi bi-file-earmark-richtext"></i>
                      <span><%= safeFileName %></span>
                    </div>
                  <% } %>
                </div>
              </div>

              <div class="social-row social-row-muted" aria-label="Social links">
                <a href="<%= safeTwitter %>" aria-label="Twitter" target="_blank" rel="noreferrer"><i class="bi bi-twitter-x"></i></a>
                <a href="<%= safeFacebook %>" aria-label="Facebook" target="_blank" rel="noreferrer"><i class="bi bi-facebook"></i></a>
                <a href="<%= safeInstagram %>" aria-label="Instagram" target="_blank" rel="noreferrer"><i class="bi bi-instagram"></i></a>
                <a href="<%= safeLinkedin %>" aria-label="LinkedIn" target="_blank" rel="noreferrer"><i class="bi bi-linkedin"></i></a>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    if (window.history.replaceState) {
      window.history.replaceState(null, null, window.location.href);
    }
  </script>
  <script src="assets/js/main.js"></script>
</body>

</html>
